S3_REGION=us-east-1
S3_BUCKET=ownly-documents
S3_ACCESS_KEY_ID=ownly
S3_SECRET_ACCESS_KEY=change-me-local-minio-secret

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AI and OCR provider adapters
